# ───────────────────────────────────────────────
# AI Ads Manager Kit — Ortam Değişkenleri
# `.env` olarak kopyala ve doldur. ASLA commit etme.
# ───────────────────────────────────────────────

# ── MCP Server Erişimi (kit'in çekirdeği) ──
# Meta Ads MCP (pipeboard) — hosted remote MCP. Token: https://pipeboard.co
PIPEBOARD_API_TOKEN=your_pipeboard_token_here
# Google+Meta+GA4 MCP — hosted SSE endpoint. URL'i kaynak repodan al:
# https://github.com/irinabuht12-oss/google-meta-ads-ga4-mcp
GA_MCP_ENDPOINT_URL=https://your-mcp-endpoint-url

# ── n8n workflow'ları için Claude API ──
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx

# ── Platform API anahtarları ──
# (Yalnızca MCP'leri SELF-HOST ediyorsan veya n8n'den doğrudan API çağırıyorsan gerekir.
#  Hosted MCP kullanıyorsan yetkilendirme MCP sağlayıcısı üzerinden yapılır.)

# Meta Ads (self-host / doğrudan Graph API)
META_ACCESS_TOKEN=your_meta_access_token_here
META_AD_ACCOUNT_ID=act_123456789
META_APP_ID=1234567890
META_APP_SECRET=your_app_secret_here

# Google Ads (self-host)
GOOGLE_ADS_DEVELOPER_TOKEN=your_developer_token_here
GOOGLE_ADS_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_ADS_CLIENT_SECRET=your_client_secret
GOOGLE_ADS_REFRESH_TOKEN=your_refresh_token
GOOGLE_ADS_CUSTOMER_ID=1234567890

# GA4
GA4_PROPERTY_ID=123456789
GA4_CLIENT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GA4_PRIVATE_KEY_PATH=./keys/ga4-private-key.pem

# TikTok Ads (deneysel — bkz. yol haritası)
TIKTOK_ACCESS_TOKEN=your_tiktok_token
TIKTOK_AD_ACCOUNT_ID=your_ad_account_id

# LinkedIn Ads (deneysel — bkz. yol haritası)
LINKEDIN_ACCESS_TOKEN=your_linkedin_token
LINKEDIN_AD_ACCOUNT_ID=your_ad_account_id

# n8n (opsiyonel)
N8N_URL=http://localhost:5678
N8N_API_KEY=your_n8n_api_key
