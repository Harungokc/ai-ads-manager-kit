        "jsonBody": "={{ JSON.stringify({\n  model: \"claude-sonnet-4-6\",\n  max_tokens: 2000,\n  system: \"Sen bir LinkedIn Ads (B2B) analistisin. Performans verisini analiz et: maliyet/lead, CTR/CPC, dönüşüm eğilimi ve B2B'ye özgü öneriler (hedefleme daraltma/genişletme, lead form, creative). Veride olmayan metrik uydurma. Maddeli, Türkçe yaz.\",\n  messages: [{ role: \"user\", content: \"Son 7 gün LinkedIn verisi:\\n\" + JSON.stringify($json) }]\n}) }}",
        "options": {}
