        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Authorization", "value": "=Bearer {{ $env.LINKEDIN_ACCESS_TOKEN }}" },
            { "name": "LinkedIn-Version", "value": "202405" },
            { "name": "X-Restli-Protocol-Version", "value": "2.0.0" }
          ]
        },
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            { "name": "q", "value": "analytics" },
            { "name": "pivot", "value": "CAMPAIGN" },
            { "name": "timeGranularity", "value": "DAILY" },
            { "name": "dateRange.start.day", "value": "={{ $now.minus({ days: 7 }).day }}" },
            { "name": "dateRange.start.month", "value": "={{ $now.minus({ days: 7 }).month }}" },
            { "name": "dateRange.start.year", "value": "={{ $now.minus({ days: 7 }).year }}" },
            { "name": "accounts", "value": "=urn:li:sponsoredAccount:{{ $env.LINKEDIN_AD_ACCOUNT_ID }}" },
            { "name": "fields", "value": "impressions,clicks,costInLocalCurrency,externalWebsiteConversions" }
          ]
        },
        "options": {}
      },
      "id": "linkedin-fetch",
      "name": "LinkedIn — Son 7 Gün Analytics",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
